#6239 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(2.E-04),#6236,
  'distance_accuracy_value','confusion accuracy');
#6240 = PRODUCT_RELATED_PRODUCT_CATEGORY('part',$,(#7));
ENDSEC;
